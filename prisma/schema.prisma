// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Student {
  id               Int                @id @default(autoincrement())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  firstName        String
  lastName         String
  notes            String?            @db.Text
  grade            Int
  className        String
  attendances      Attendance[]
  visitations      Visitation[]
  GroupsOnStudents GroupsOnStudents[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  day       Int
  end       Int
  Student   Student? @relation(fields: [studentId], references: [id])
  studentId Int?
}

model Visitation {
  id        Int      @id @default(autoincrement())
  date      DateTime
  start     Int
  end       Int?
  Student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId Int

  @@unique([date, studentId])
}

model User {
  id       Int    @id @default(autoincrement())
  role     Role   @default(DEFAULT)
  username String @unique
  password String
}

enum Role {
  OWNER
  ADMIN
  DEFAULT
}

model Group {
  id               Int                @id @default(autoincrement())
  name             String
  color            String?
  GroupsOnStudents GroupsOnStudents[]
  list             List               @relation(fields: [listId], references: [id])
  listId           Int
}

model GroupsOnStudents {
  student   Student @relation(fields: [studentId], references: [id])
  studentId Int
  group     Group   @relation(fields: [groupId], references: [id])
  groupId   Int

  @@id([studentId, groupId])
}

model List {
  id      Int          @id @default(autoincrement())
  name    String
  options ListOptions?
  Group   Group[]
}

model ListOptions {
  id                   Int                   @id @default(autoincrement())
  recordTime           RecordTime // record time
  List                 List                  @relation(fields: [listId], references: [id])
  listId               Int                   @unique
  ListTableInformation ListTableInformation?
  cycle                ListCycleType         @default(DAILY)
  activations          ListActivation[]
  manageTime           TimeManagement        @default(STUDENT) // decides if the list or the student manages their start and end time 
}

enum TimeManagement {
  LIST
  STUDENT
}

enum RecordTime {
  START
  START_END
}

enum ListCycleType {
  DAILY
  WEEKLY
  MONTHLY
}

model ListTableInformation {
  id            Int              @id @default(autoincrement())
  studentName   Boolean
  className     Boolean
  time          Boolean
  notes         ListStudentNotes
  groupColor    Boolean
  ListOptions   ListOptions      @relation(fields: [listOptionsId], references: [id])
  listOptionsId Int              @unique
}

enum ListStudentNotes {
  NONE
  MARKED
  SHORTENED
  FULL
}

model ListActivation {
  id            Int          @id @default(autoincrement())
  day           Int // 0 (monday) to 6 (sunday)
  startTime     Int
  startBuffer   Int // buffer in minutes
  endTime       Int
  endBuffer     Int // buffer in minutes
  ListOptions   ListOptions? @relation(fields: [listOptionsId], references: [id])
  listOptionsId Int?
}
